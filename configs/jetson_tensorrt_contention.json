{
  "run": {
    "name": "jetson_tensorrt_contention_smoke",
    "input_source": "dummy",
    "overload_backlog_threshold": 2
  },
  "tasks": [
    {
      "name": "detector_trt",
      "model_path": "models/detector.onnx",
      "engine_path": "models/detector.plan",
      "priority": 100,
      "target_fps": 15,
      "latency_budget_ms": 80,
      "queue_size": 3,
      "drop_policy": "drop_oldest",
      "worker": "tensorrt",
      "worker_options": {
        "precision": "fp16",
        "warmup_runs": 0,
        "device_id": 0,
        "allow_engine_build": false
      }
    },
    {
      "name": "classifier_trt",
      "model_path": "models/classifier.onnx",
      "engine_path": "models/detector.plan",
      "priority": 10,
      "target_fps": 5,
      "latency_budget_ms": 250,
      "queue_size": 3,
      "drop_policy": "drop_oldest",
      "worker": "tensorrt",
      "worker_options": {
        "precision": "fp16",
        "warmup_runs": 0,
        "device_id": 0,
        "allow_engine_build": false
      }
    }
  ]
}
