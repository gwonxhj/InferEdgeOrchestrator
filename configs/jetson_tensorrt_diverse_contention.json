{
  "run": {
    "name": "jetson_tensorrt_diverse_contention_smoke",
    "input_source": "dummy",
    "overload_backlog_threshold": 2
  },
  "tasks": [
    {
      "name": "detector_trt",
      "model_path": "models/generated/detector_tiny.onnx",
      "engine_path": "models/generated/detector_tiny_fp16.plan",
      "priority": 100,
      "target_fps": 15,
      "latency_budget_ms": 80,
      "queue_size": 3,
      "drop_policy": "drop_oldest",
      "worker": "tensorrt",
      "worker_options": {
        "precision": "fp16",
        "warmup_runs": 0,
        "device_id": 0,
        "allow_engine_build": false,
        "profile_name": "detector_tiny_fp16",
        "input_bindings": {
          "detector_input": [1, 3, 16, 16]
        },
        "output_bindings": {
          "detector_scores": [1, 6]
        }
      }
    },
    {
      "name": "classifier_trt",
      "model_path": "models/generated/classifier_tiny.onnx",
      "engine_path": "models/generated/classifier_tiny_fp16.plan",
      "priority": 10,
      "target_fps": 5,
      "latency_budget_ms": 250,
      "queue_size": 3,
      "drop_policy": "drop_oldest",
      "worker": "tensorrt",
      "worker_options": {
        "precision": "fp16",
        "warmup_runs": 0,
        "device_id": 0,
        "allow_engine_build": false,
        "profile_name": "classifier_tiny_fp16",
        "input_bindings": {
          "classifier_input": [1, 16]
        },
        "output_bindings": {
          "classifier_logits": [1, 4]
        }
      }
    }
  ]
}
