{
  "run": {
    "name": "agent_3_workload_normal",
    "scenario_mode": "normal",
    "overload_backlog_threshold": 8,
    "frame_interval_ms": 10,
    "input_source": "dummy"
  },
  "tasks": [
    {
      "name": "safety_monitor_agent",
      "agent_manifest_path": "examples/agent_runtime/safety_agent_manifest.json",
      "target_fps": 10,
      "queue_size": 3,
      "drop_policy": "drop_oldest",
      "worker": "dummy",
      "simulated_latency_ms": 4,
      "emit_every_cycles": 1
    },
    {
      "name": "vision_agent",
      "agent_manifest_path": "examples/agent_runtime/vision_agent_manifest.json",
      "runtime_result_path": "examples/agent_runtime/vision_runtime_result.json",
      "target_fps": 15,
      "queue_size": 4,
      "drop_policy": "drop_oldest",
      "worker": "dummy",
      "simulated_latency_ms": 24,
      "emit_every_cycles": 1
    },
    {
      "name": "voice_command_agent",
      "agent_manifest_path": "examples/agent_runtime/voice_agent_manifest.json",
      "target_fps": 2,
      "queue_size": 2,
      "drop_policy": "drop_newest",
      "worker": "dummy",
      "simulated_latency_ms": 36,
      "emit_every_cycles": 4
    }
  ]
}
