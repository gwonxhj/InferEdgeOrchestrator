{
  "run": {
    "name": "agent_multi_workload_sustained_local",
    "scenario_mode": "sustained_high_load",
    "overload_backlog_threshold": 4,
    "frame_interval_ms": 5,
    "input_source": "dummy"
  },
  "tasks": [
    {
      "name": "safety_monitor_agent",
      "agent_manifest_path": "examples/agent_runtime/safety_agent_manifest.json",
      "target_fps": 10,
      "queue_size": 2,
      "drop_policy": "drop_oldest",
      "worker": "dummy",
      "simulated_latency_ms": 6,
      "emit_every_cycles": 1,
      "worker_options": {
        "workload_type": "telemetry_monitor",
        "runtime_loop": "safety_monitor_loop",
        "ingress_profile": "periodic_monitor",
        "implementation": "synthetic_adapter",
        "expected_runtime_mode": "periodic",
        "preferred_device": "cpu"
      }
    },
    {
      "name": "vision_agent",
      "agent_manifest_path": "examples/agent_runtime/vision_agent_manifest.json",
      "runtime_result_path": "examples/agent_runtime/vision_runtime_result.json",
      "target_fps": 30,
      "queue_size": 3,
      "drop_policy": "drop_oldest",
      "worker": "dummy",
      "simulated_latency_ms": 72,
      "emit_every_cycles": 1,
      "worker_options": {
        "workload_type": "realtime_vision",
        "runtime_loop": "yolo_detection_loop",
        "ingress_profile": "frame_queue",
        "implementation": "synthetic_adapter",
        "expected_runtime_mode": "sustained",
        "preferred_device": "gpu"
      }
    },
    {
      "name": "voice_command_agent",
      "agent_manifest_path": "examples/agent_runtime/voice_agent_manifest.json",
      "target_fps": 8,
      "queue_size": 2,
      "drop_policy": "drop_newest",
      "worker": "dummy",
      "simulated_latency_ms": 135,
      "emit_every_cycles": 2,
      "worker_options": {
        "workload_type": "voice_command",
        "runtime_loop": "whisper_command_burst",
        "ingress_profile": "fastapi_concurrent_request",
        "implementation": "synthetic_adapter",
        "expected_runtime_mode": "burst",
        "preferred_device": "cpu"
      }
    }
  ]
}
